# Copy to `.env` (git-ignored) and fill in. docker compose auto-loads `.env`.
# This file holds only NON-SECRET knobs and pointers. Real secret VALUES belong
# in mounted files referenced by the config `*_ref` variables (scheme:opaque),
# not here.

# Version string baked into the image at build time (release images only).
# VALLET_VERSION=1.0.0

# Password for the opt-in forward-looking postgres profile
# (`docker compose --profile postgres up`). Required only if you enable it.
# POSTGRES_PASSWORD=change-me-strong-random
